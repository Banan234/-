# Файл документирует переменные окружения, необходимые для локального запуска, SMTP, SEO, аналитики и мониторинга.
# Здесь должны быть только безопасные примеры и пустые значения. Реальные
# production-секреты храните вне Git и передавайте в контейнер через Docker
# env-файл, Docker secrets или secret manager инфраструктуры.

# Скопируйте файл в `.env` (он в .gitignore) и заполните под свою установку.
# Пустые значения допустимы не для всех фич:
# например, без VITE_YANDEX_METRIKA_ID не подгрузится скрипт Метрики.
# Формы заявок в production требуют либо валидный SMTP-блок ниже,
# либо явный FORMS_ENABLED=false. В локальном шаблоне они выключены.

# ─── Express backend (server.js) ────────────────────────────────────────────
# Порт, на котором поднимается API. Vite проксирует /api/* сюда.
PORT=3001

# SMTP для отправки заявок «Получить КП» и обратного звонка.
# Пример: для Яндекс.Почты использовать app password (двухфакторка обязательна).
# В production сервер стартует только в одном из двух режимов:
#   1) FORMS_ENABLED=true  + заполнены SMTP_* и transporter.verify() успешен
#   2) FORMS_ENABLED=false + формы /api/quote и /api/lead-request отвечают 503
# В staging/dev при неуспешном verify сервер явно пишет инструкцию в лог,
# а /api/forms/health и POST форм возвращают недоступность без технических деталей.
FORMS_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# From-заголовок — рекомендуется писать через display-name, чтобы письмо
# не попадало в спам: SMTP_FROM="ООО ЮжУралЭлектроКабель <noreply@example.ru>"
SMTP_FROM=

# Адрес, на который менеджеры будут получать заявки из формы КП.
QUOTE_TO_EMAIL=

# Устойчивость SMTP: transporter создаётся один раз на app и использует pool.
# Таймауты не дают медленному SMTP держать HTTP-запросы бесконечно.
SMTP_POOL=true
SMTP_POOL_MAX_CONNECTIONS=2
SMTP_POOL_MAX_MESSAGES=100
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_SEND_RETRIES=1
SMTP_RETRY_DELAY_MS=750

# Диагностика форм после запуска:
#   curl http://localhost:3001/api/forms/health
# Ответ не содержит секретов и показывает formsEnabled/smtpConfigured/smtpVerified/smtpReady.

# CORS-allowlist через запятую. В проде фронт и API на одном домене —
# можно оставить пустым (тогда кросс-доменные запросы будут отвергнуты).
# Для dev: ALLOWED_ORIGINS=http://localhost:5173
ALLOWED_ORIGINS=

# Доверенные reverse-proxy, от которых Express принимает X-Forwarded-For.
# Формат proxy-addr: loopback, linklocal, uniquelocal, IP или CIDR через запятую.
# По умолчанию в коде используется loopback — подходит для Nginx на той же машине.
# Для CDN/балансера укажите только IP/CIDR ваших промежуточных proxy.
TRUSTED_PROXY_IPS=loopback

# Токен для закрытого endpoint `/api/runtime`.
# Если пусто, runtime-метрики недоступны по HTTP.
INTERNAL_METRICS_TOKEN=

# Логи под нагрузкой. 4xx/5xx и медленные запросы логируются всегда.
# Успешные 2xx/3xx в production по умолчанию семплируются в коде на 10%,
# чтобы stdout/Docker logging не становился узким местом при наплыве.
LOG_LEVEL=info
ACCESS_LOG_SUCCESS_SAMPLE_RATE=0.1
ACCESS_LOG_SLOW_MS=1000

# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# Идентификатор счётчика Яндекс.Метрики (число). Если пусто — все вызовы
# trackEvent/trackPageview становятся no-op, скрипт mc.yandex.ru не подгружается.
VITE_YANDEX_METRIKA_ID=

# DSN Sentry или GlitchTip для трекинга фронтовых ошибок. Если пусто —
# captureException становится console.error, SDK даже не догружается
# (lazy import → отдельный chunk не запрашивается). Совместимо с GlitchTip
# (его DSN — тот же формат, просто с другим эндпоинтом).
# Пример: https://abc123@glitchtip.example.ru/1
VITE_SENTRY_DSN=
# Окружение в Sentry: production / staging / preview. По умолчанию — Vite MODE.
VITE_SENTRY_ENVIRONMENT=
# Версия релиза (например, тег git). Помогает связывать ошибки с конкретным деплоем.
VITE_SENTRY_RELEASE=
# Доля транзакций в performance-мониторинге (0..1). По умолчанию 0 — выключено.
VITE_SENTRY_TRACES_SAMPLE_RATE=

# Канонический URL продакшен-сайта (без слэша на конце). Используется в:
#   - sitemap.xml / robots.txt (генерируются importPrice.js);
#   - <link rel="canonical"> и og:url из useSEO;
#   - JSON-LD Product/Organization (поля url, seller.url и т.п.).
# Также прокидывается в Node-скрипты через SITE_URL — оба значения должны совпадать.
VITE_SITE_URL=http://localhost:5173
SITE_URL=http://localhost:5173

# ─── Автоматический импорт прайса ───────────────────────────────────────────
# Прямой URL Excel-файла поставщика (kabelhome.ru). Если задано — команды
# `npm run import:price:remote` и cron-задача скачивают свежий прайс и
# перезаписывают data/price.xls перед парсингом.
# Точный URL прайса нужно подсмотреть на сайте поставщика (страница «Прайс»
# / «Скачать»). Пример: https://kabelhome.ru/upload/price.xls
PRICE_URL=
# Максимальный размер скачиваемого PRICE_URL в байтах. По умолчанию: 52428800
# (50 МБ). Скрипт проверяет Content-Length и прерывает streaming-чтение при
# превышении.
PRICE_DOWNLOAD_MAX_BYTES=

# Куда importPrice.js пишет публичные runtime-артефакты:
# price.xls, redirects.*, sitemap*.xml, robots.txt.
# Для обычной локальной разработки оставьте пустым (будет ./public).
# Docker compose задаёт /app/data/public, чтобы web-контейнер видел обновления.
PUBLIC_ARTIFACTS_DIR=
# Шаблон Vite index.html для runtime-prerender карточек при PUBLIC_ARTIFACTS_DIR.
# Docker runtime image кладёт его в /app/dist/index.html; локально это ./dist.
PRERENDER_TEMPLATE_DIR=

# Сколько product HTML писать в web-образ при npm run build:prod.
# По умолчанию 720 важных позиций из начала каталога; sitemap остаётся полным,
# а длинный хвост обслуживается runtime product-prerender из volume или SPA
# fallback. Значения: целое >= 0, "all" для прежнего полного prerender.
PRODUCT_PRERENDER_LIMIT=720
# Всегда включать эти SKU/slug в build-time prerender сверх лимита.
# Разделители: запятая, пробел или ;. Можно указывать /product/<slug>.
PRODUCT_PRERENDER_INCLUDE=

# ─── Docker deploy / staging / rollback ─────────────────────────────────────
# DEPLOY_TAG — immutable tag production-релиза. Для локального docker compose
# можно оставить latest, на VPS лучше ставить git SHA или дату релиза.
DEPLOY_TAG=latest
APP_IMAGE=yuzhural-site-app
WEB_IMAGE=yuzhural-site-web
# Локальный bind production Nginx для внешнего TLS reverse proxy.
# Не задавайте 0.0.0.0:80 на публичном хосте: внешний доступ должен идти через TLS.
WEB_HTTP_BIND=127.0.0.1:8080

# Staging поднимается отдельным compose-файлом; если production уже слушает 8080,
# задайте STAGING_HTTP_PORT=8081 или другой свободный локальный порт.
STAGING_DEPLOY_TAG=staging
STAGING_HTTP_PORT=8080
STAGING_SITE_URL=http://localhost:8080
STAGING_YANDEX_METRIKA_ID=
STAGING_SENTRY_DSN=
STAGING_SENTRY_TRACES_SAMPLE_RATE=0
