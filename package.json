{
  "name": "yuzhural-site",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "start": "concurrently \"npm run dev\" \"npm run server\"",
    "import:price": "node scripts/importPrice.js",
    "import:price:remote": "node scripts/importPrice.js \"$PRICE_URL\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "vite build",
    "prerender": "node scripts/prerender.js",
    "build:ssr": "vite build --ssr src/entry-server.jsx --outDir dist/server",
    "precompress": "node scripts/precompress.js",
    "build:prod": "vite build && npm run build:ssr && node scripts/prerender.js && npm run precompress",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "load:test": "node scripts/loadTest.js",
    "load:soak": "LOAD_DURATION_SEC=1800 LOAD_CONCURRENCY=50,100,200 node scripts/loadTest.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@sentry/react": "^10.50.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "nodemailer": "^8.0.4",
    "proxy-addr": "^2.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.6.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
